# AgendAI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do arquivo .env — ele está no .gitignore

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (IA) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Evolution API (WhatsApp Gateway) ─────────────
EVOLUTION_API_URL=https://sua-evolution.seudominio.com
EVOLUTION_API_KEY=sua-chave-evolution-api
EVOLUTION_INSTANCE=nome-da-instancia

# ── Google Calendar ───────────────────────────────
GOOGLE_CALENDAR_ID=seu-email@gmail.com
# Credenciais OAuth2 — geradas no Google Cloud Console
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# ── n8n ──────────────────────────────────────────
N8N_WEBHOOK_URL=https://seu-n8n.app.n8n.cloud/webhook/
WEBHOOK_SECRET=gere-um-token-aleatorio-seguro-aqui

# ── Dashboard (Variáveis para o frontend Vite) ───
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_N8N_WEBHOOK_URL=https://seu-n8n.app.n8n.cloud/webhook/

# ── Opcional: SMTP para e-mails ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail
